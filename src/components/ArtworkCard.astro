---
import { Image } from "astro:assets";
const { artwork } = Astro.props;

const images = import.meta.glob<{ default: string }>(
  "../../public/artworks/*-watermarked.webp",
  { eager: true }
);

function resolveArtworkImage(imagePath: string) {
  if (!imagePath) return null;

  // Content frontmatter may reference the file via an absolute path (e.g. /artworks/kranich.webp)
  // but the Vite glob keys are relative to this component file.
  const filename = imagePath.replace(/^\/?artworks\//, "");
  const key = `../../public/artworks/${filename}`;

  const match = images[key];
  if (!match) return null;

  return match.default;
}

const image = resolveArtworkImage(artwork.data.image) ?? "";
---

<script>
  // Disable right-click and drag on images
  document.addEventListener("contextmenu", (e) => {
    const target = e.target as HTMLElement | null;
    if (target?.tagName === "IMG") {
      e.preventDefault();
    }
  });

  document.addEventListener("dragstart", (e) => {
    const target = e.target as HTMLElement | null;
    if (target?.tagName === "IMG") {
      e.preventDefault();
    }
  });
</script>

<div class="min-h-screen py-12 lg:py-20">
  <div class="container-fluid mx-auto">
    <div class="max-w-4xl mx-auto">
      <!-- Back button -->
      <a
        href="/kunstmitt"
        class="inline-flex items-center gap-2 text-amber-700 hover:text-amber-900 transition-colors duration-200 mb-8 group"
      >
        <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Gallery
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Image Section -->
        <div class="space-y-6">
          <div class="glass-effect rounded-2xl overflow-hidden card-hover">
            <Image
              src={image}
              widths={[600, 1200, 1800]}
              alt={artwork.data.title}
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Content Section -->
        <div class="space-y-8">
          <div class="space-y-4">
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-light text-gradient leading-tight">
              {artwork.data.title}
            </h1>

            <div class="flex flex-wrap gap-4 text-sm text-amber-700">
              <span class="glass-effect px-3 py-1 rounded-full">
                {artwork.data.year}
              </span>
              <span class="glass-effect px-3 py-1 rounded-full">
                {artwork.data.medium}
              </span>
            </div>
          </div>

          <div class="prose prose-amber max-w-none">
            <p class="text-amber-800 text-lg leading-relaxed">
              {artwork.body}
            </p>
          </div>

          <!-- Decorative element -->
          <div class="w-16 h-px bg-gradient-to-r from-transparent via-amber-300 to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</div>