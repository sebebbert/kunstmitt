---
import { Image } from "astro:assets";
const { artwork } = Astro.props;

const images = import.meta.glob(
  "../assets/artworks/*.{webp,jpg,png}",
  { eager: true }
);

function resolveArtworkImage(imagePath: string) {
  if (!imagePath) return null;

  // Content frontmatter may reference the file via an absolute path (e.g. /src/assets/artworks/kranich.webp)
  // but the Vite glob keys are relative to this component file.
  const filename = imagePath.replace(/^\/?src\/assets\/artworks\//, "");
  const key = `../assets/artworks/${filename}`;

  const match = images[key];
  if (!match) return null;

  return match.default;
}

const image = resolveArtworkImage(artwork.data.image);
---

<div class="space-y-2">
  <Image
    src={image}
    widths={[600, 1200, 1800]}
    alt={artwork.data.title}
    class="w-full object-cover"
  />

  <div>
    <h3 class="text-lg font-semibold">{artwork.data.title}</h3>
    <p class="text-sm text-gray-500">
      {artwork.data.year} · {artwork.data.medium}
    </p>
  </div>
</div>